{
    "name": "hatchyu/string-utils",
    "description": "Smart PHP string utilities for slugging, casing, transliteration, and unique hash generation",
    "license": "MIT",
    "authors": [
        {
            "name": "Raju Koyilandy",
            "email": "hello@rajeshmk.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Hatchyu\\String\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hatchyu\\String\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit"
    }
}
